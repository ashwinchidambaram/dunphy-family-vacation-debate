direction: down

title: {
  label: System Architecture
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    font-color: "#e5e2e1"
  }
}

entry: Entry Points {
  style: {
    fill: "#1c1b1b"
    stroke: "#414755"
    border-radius: 12
    font-color: "#e5e2e1"
  }

  terminal: "main.py / terminal_app.py\n(Terminal UI)" {
    style: {
      fill: "#353534"
      stroke: "#8b90a0"
      border-radius: 8
      font-color: "#e5e2e1"
    }
  }

  browser: "browser_app.py\n(FastAPI + SSE)" {
    style: {
      fill: "#353534"
      stroke: "#8b90a0"
      border-radius: 8
      font-color: "#e5e2e1"
    }
  }
}

orchestrator: "FamilyDiscussionOrchestrator\ndiscussion/orchestrator.py" {
  style: {
    fill: "#201f1f"
    stroke: "#adc6ff"
    border-radius: 12
    font-color: "#e5e2e1"
    stroke-width: 2
  }

  features: |md
    - Phase state machine
    - Per-phase speaker ordering
    - Session ID guards
    - Auto-retry + manual recovery
    - Output sanitization
  | {
    style: {
      font-color: "#c1c6d7"
      font-size: 13
    }
  }
}

config: Configuration {
  style: {
    fill: "#1c1b1b"
    stroke: "#414755"
    border-radius: 12
    font-color: "#e5e2e1"
  }

  phases: "PhaseDefinitions\ndiscussion/phases.py\n\nPhase 0–4 configs\nspeaker_order\ntoken_limit\nparent/child instructions" {
    style: {
      fill: "#353534"
      stroke: "#f1c100"
      border-radius: 8
      font-color: "#e5e2e1"
    }
  }

  tracker: "TokenTracker\nutils/token_tracker.py\n\nPer-agent tallies\nPer-phase breakdown\nCost calculation" {
    style: {
      fill: "#353534"
      stroke: "#8b90a0"
      border-radius: 8
      font-color: "#e5e2e1"
    }
  }
}

agents: Agent Wrappers {
  style: {
    fill: "#1c1b1b"
    stroke: "#414755"
    border-radius: 12
    font-color: "#e5e2e1"
  }

  phil: Phil {
    style: {
      fill: "#adc6ff"
      stroke: "#adc6ff"
      border-radius: 8
      font-color: "#001a41"
      bold: true
    }
  }

  claire: Claire {
    style: {
      fill: "#ffb3b5"
      stroke: "#ffb3b5"
      border-radius: 8
      font-color: "#680019"
      bold: true
    }
  }

  haley: Haley {
    style: {
      fill: "#f1c100"
      stroke: "#f1c100"
      border-radius: 8
      font-color: "#241a00"
      bold: true
    }
  }

  alex: Alex {
    style: {
      fill: "#8b90a0"
      stroke: "#8b90a0"
      border-radius: 8
      font-color: "#131313"
      bold: true
    }
  }

  luke: Luke {
    style: {
      fill: "#ffb4ab"
      stroke: "#ffb4ab"
      border-radius: 8
      font-color: "#690005"
      bold: true
    }
  }

  manny: Manny {
    style: {
      fill: "#4b8eff"
      stroke: "#4b8eff"
      border-radius: 8
      font-color: "#ffffff"
      bold: true
    }
  }
}

personas: "family-prompts/*.md\nIdentity + Relationships + Vacation Style" {
  style: {
    fill: "#353534"
    stroke: "#414755"
    border-radius: 8
    font-color: "#c1c6d7"
    font-size: 14
  }
}

llm: LLM Backend {
  style: {
    fill: "#1c1b1b"
    stroke: "#414755"
    border-radius: 12
    font-color: "#e5e2e1"
  }

  client: "LLMClient\nutils/llm_client.py\n\nGoogle ADK\nLlmAgent + Runner\nInMemorySessionService" {
    style: {
      fill: "#353534"
      stroke: "#4b8eff"
      border-radius: 8
      font-color: "#e5e2e1"
    }
  }

  gemini: "Gemini 2.5 Flash\n(Google API)" {
    style: {
      fill: "#4b8eff"
      stroke: "#4b8eff"
      border-radius: 8
      font-color: "#ffffff"
      bold: true
    }
  }

  mock: "Mock Mode\n(No API needed)" {
    style: {
      fill: "#353534"
      stroke: "#8b90a0"
      border-radius: 8
      font-color: "#8b90a0"
      stroke-dash: 5
    }
  }
}

# Connections
entry.terminal -> orchestrator: {
  style: {
    stroke: "#8b90a0"
  }
}

entry.browser -> orchestrator: {
  style: {
    stroke: "#8b90a0"
  }
}

orchestrator -> entry.browser: "callbacks\non_message()\non_phase_change()\non_metrics_update()" {
  style: {
    stroke: "#adc6ff"
    stroke-dash: 3
    font-color: "#8b90a0"
    font-size: 11
  }
}

orchestrator -> config.phases: {
  style: {
    stroke: "#f1c100"
  }
}

orchestrator -> config.tracker: {
  style: {
    stroke: "#8b90a0"
  }
}

orchestrator -> agents: {
  style: {
    stroke: "#adc6ff"
    stroke-width: 2
  }
}

agents.phil -> personas: {style: {stroke: "#adc6ff"}}
agents.claire -> personas: {style: {stroke: "#ffb3b5"}}
agents.haley -> personas: {style: {stroke: "#f1c100"}}
agents.alex -> personas: {style: {stroke: "#8b90a0"}}
agents.luke -> personas: {style: {stroke: "#ffb4ab"}}
agents.manny -> personas: {style: {stroke: "#4b8eff"}}

orchestrator -> llm.client: {
  style: {
    stroke: "#4b8eff"
    stroke-width: 2
  }
}

llm.client -> llm.gemini: {
  style: {
    stroke: "#4b8eff"
  }
}

llm.client -> llm.mock: {
  style: {
    stroke: "#8b90a0"
    stroke-dash: 5
  }
}
